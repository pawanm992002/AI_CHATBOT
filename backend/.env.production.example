# Environment Name
APP_ENV=production

# MongoDB Database Settings
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB_NAME="chatbot_db_production"

# API Keys
OPENAI_API_KEY="sk-proj-..."
FIRECRAWL_API_KEY="fc-..."

# Security
JWT_SECRET="generate-a-secure-random-secret-for-production"
ALLOWED_ORIGINS="https://production-dashboard.yourdomain.com"
ENFORCE_DOMAIN=False

# Cookie Settings
# (Use secure=True and samesite=none if frontend is hosted on a separate domain from the API over HTTPS)
COOKIE_SECURE=True
COOKIE_SAMESITE=none

# Base API URL used by the dashboard
VITE_API_BASE_URL="https://production-api.yourdomain.com"

# Redis Cache URI
REDIS_URI="redis://localhost:6379/0"
